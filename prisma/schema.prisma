generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  STAFF
}

enum BookingStatus {
  HELD
  CONFIRMED
  CANCELLED
  EXPIRED
  CHECKED_IN
  CHECKED_OUT
  NO_SHOW
}

enum RuleType {
  BASE
  WEEKDAY
  DATE_RANGE
  EXTRA_GUEST
}

enum ContentType {
  TEXT
  RICH_TEXT
  IMAGE
  JSON
}

model Property {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  address            String?
  phone              String?
  zalo                String?
  email               String?
  defaultHoldMinutes Int                 @default(120)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  accommodationTypes AccommodationType[]
  users              User[]
  contentBlocks      ContentBlock[]
}

model AccommodationType {
  id            String        @id @default(cuid())
  propertyId    String
  name          String
  slug          String        @unique
  shortName     String
  description   String
  longDescription String?
  maxGuests     Int
  baseGuests    Int           @default(2)
  bedrooms      Int           @default(1)
  beds          Int           @default(1)
  bathrooms     Int           @default(1)
  area          Int?
  basePrice     Decimal       @db.Decimal(12, 0)
  heroImage     String
  gallery       Json
  amenities     Json
  featured      Boolean       @default(false)
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  property      Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  units         Unit[]
  rateRules     RateRule[]

  @@index([propertyId, active])
}

model Unit {
  id                  String            @id @default(cuid())
  accommodationTypeId String
  name                String
  code                String            @unique
  active              Boolean           @default(true)
  accommodationType   AccommodationType @relation(fields: [accommodationTypeId], references: [id], onDelete: Cascade)
  bookings            Booking[]
  availabilityBlocks  AvailabilityBlock[]

  @@index([accommodationTypeId, active])
}

model RateRule {
  id                  String            @id @default(cuid())
  accommodationTypeId String
  name                String
  type                RuleType
  priority            Int               @default(0)
  amount              Decimal           @db.Decimal(12, 0)
  startDate           DateTime?         @db.Date
  endDate             DateTime?         @db.Date
  weekdays            Int[]
  minGuests           Int?
  active              Boolean           @default(true)
  accommodationType   AccommodationType @relation(fields: [accommodationTypeId], references: [id], onDelete: Cascade)

  @@index([accommodationTypeId, active, priority])
}

model Guest {
  id        String    @id @default(cuid())
  fullName  String
  phone     String
  email     String?
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]

  @@index([phone])
}

model Booking {
  id             String        @id @default(cuid())
  code           String        @unique
  unitId         String
  guestId        String
  status         BookingStatus @default(HELD)
  checkIn        DateTime      @db.Date
  checkOut       DateTime      @db.Date
  guests         Int
  totalAmount    Decimal       @db.Decimal(12, 0)
  priceSnapshot  Json
  guestNote      String?
  internalNote   String?
  holdExpiresAt  DateTime?
  idempotencyKey String?       @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  unit           Unit          @relation(fields: [unitId], references: [id])
  guest          Guest         @relation(fields: [guestId], references: [id])
  payments       Payment[]

  @@index([unitId, checkIn, checkOut, status])
  @@index([status, holdExpiresAt])
}

model AvailabilityBlock {
  id        String   @id @default(cuid())
  unitId    String
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now())
  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([unitId, startDate, endDate])
}

model Payment {
  id        String   @id @default(cuid())
  bookingId String
  amount    Decimal  @db.Decimal(12, 0)
  method    String
  reference String?
  note      String?
  paidAt    DateTime @default(now())
  createdBy String?
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, paidAt])
}

model User {
  id           String    @id @default(cuid())
  propertyId   String
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(STAFF)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  property     Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model ContentBlock {
  id         String      @id @default(cuid())
  propertyId String
  key        String      @unique
  label      String
  type       ContentType
  value      String
  updatedAt  DateTime    @updatedAt
  property   Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
